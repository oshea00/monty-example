import asyncio

# Phase 1 user IDs and arguments
user_ids = [1, 2, 3, 4, 5]
quarter = 'Q3'
category = 'travel'

# Create coroutines to fetch expenses for each user
async def fetch_expenses(user_id):
    return await get_expenses(user_id=user_id, quarter=quarter, category=category)

# Gather expenses for all users
expenses_data = await asyncio.gather(*(fetch_expenses(user_id) for user_id in user_ids))

# Process the expenses to calculate total for each member
total_expenses = []
for expense in expenses_data:
    user_id = expense['user_id']
    total_amount = sum(item['amount'] for item in expense['expenses'])
    total_expenses.append({'user_id': user_id, 'total_expense': total_amount})

total_expenses
