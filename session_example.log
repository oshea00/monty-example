department = 'Engineering'
quarter = 'Q3'
category = 'travel'
keyword = 'flight'

# Fetch team members
team_data = await get_team_members(department)
members = team_data['members']

# Prepare tasks to fetch expenses
expense_tasks = [get_expenses(member['id'], quarter, category) for member in members]
expenses_data = await asyncio.gather(*expense_tasks)

# Filter expenses containing 'flight'
filtered_expenses = []

